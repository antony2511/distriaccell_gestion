# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Gemini API (optional - for AI features)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Configuración SMTP para Nodemailer (backend de emails)
# Gmail: SMTP_HOST=smtp.gmail.com  PORT=587  SECURE=false  (usar App Password)
# Hostinger: SMTP_HOST=smtp.hostinger.com  PORT=465  SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Distriaccell <reportes@distriaccell.com>
